{
  "schemaVersion": 1,
  "id": "dfvibe",
  "version": "${version}",
  "name": "DF Vibe",
  "description": "Sync DiamondFire plot code to local .py files and back with /df commands. Built on a fork of CodeClient (its dev utilities included) — one jar, no separate CodeClient install. Dev mode only.",
  "authors": [
    "Avalenced"
  ],
  "contact": {
    "homepage": "https://github.com/Avalenced/DF-Vibe",
    "repo": "https://github.com/Avalenced/DF-Vibe",
    "issues": "https://github.com/Avalenced/DF-Vibe/issues",
    "sources": "https://github.com/Avalenced/DF-Vibe"
  },
  "contributors": [
    "GeorgeRNG (CodeClient)",
    "RedVortex (CodeClient)",
    "sylviameows (CodeClient)",
    "BlazeMCworld (CodeClient)"
  ],
  "license": "MIT",
  "icon": "assets/codeclient/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "dev.dfonline.codeclient.CodeClient",
      "com.dfvibe.DfVibeClient"
    ],
    "modmenu": [
      "dev.dfonline.codeclient.config.ModMenuIntegration"
    ]
  },
  "accessWidener" : "codeclient.accesswidener",
  "mixins": [
    "CodeClient.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.9",
    "minecraft": "1.21.11",
    "java": ">=21",
    "fabric-api": "*",
    "yet_another_config_lib_v3": ">=3.6.1+1.21.2-fabric"
  },
  "recommends": {
    "modmenu": ">=12.0.0-beta.1"
  },
  "breaks": {
    "codeclient": "*"
  }
}
